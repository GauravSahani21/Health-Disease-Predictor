# Backend Environment Variables

# Node Environment
NODE_ENV=development

# Server
PORT=5000

# MongoDB
NODE_ENV=development # Change to 'production' on your server
FRONTEND_URL=http://localhost:3000

# MongoDB Setup
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/health_predictor

# Security Keys
JWT_SECRET=your_jwt_secret_here
GOOGLE_AI_API_KEY=your_google_ai_key_here

# Microservice URLs (Use these when running via Docker Compose)
# TEXT_ML_URL=http://ml_text:8001
# IMAGE_ML_URL=http://ml_image:8002
# BRAIN_ML_URL=http://ml_brain:8003
# FACE_ML_URL=http://ml_face:80043
FACE_ML_URL=http://localhost:8004

# S3 Storage - Using Cloudinary for local dev (no MinIO needed)
# Option 1: Cloudinary (Recommended for simplicity)
# S3_ENDPOINT=https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME
# S3_ACCESS_KEY=your_cloudinary_api_key
# S3_SECRET_KEY=your_cloudinary_api_secret
# S3_BUCKET=your_cloudinary_folder
# S3_REGION=auto

# Option 2: Local file storage (simplest for development)
S3_ENDPOINT=local
S3_ACCESS_KEY=local
S3_SECRET_KEY=local
S3_BUCKET=uploads
S3_REGION=local

# CORS
FRONTEND_URL=http://localhost:3000

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Logging
LOG_LEVEL=info
