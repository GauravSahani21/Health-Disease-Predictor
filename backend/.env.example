# Backend Environment Variables

# Node Environment
NODE_ENV=development

# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://mongo:27017/health_predictor

# JWT
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=3600

# ML Services (Local Development - use localhost instead of docker network)
TEXT_ML_URL=http://localhost:8001
IMAGE_ML_URL=http://localhost:8002
BRAIN_ML_URL=http://localhost:8003
FACE_ML_URL=http://localhost:8004

# S3 Storage - Using Cloudinary for local dev (no MinIO needed)
# Option 1: Cloudinary (Recommended for simplicity)
# S3_ENDPOINT=https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME
# S3_ACCESS_KEY=your_cloudinary_api_key
# S3_SECRET_KEY=your_cloudinary_api_secret
# S3_BUCKET=your_cloudinary_folder
# S3_REGION=auto

# Option 2: Local file storage (simplest for development)
S3_ENDPOINT=local
S3_ACCESS_KEY=local
S3_SECRET_KEY=local
S3_BUCKET=uploads
S3_REGION=local

# CORS
FRONTEND_URL=http://localhost:3000

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Logging
LOG_LEVEL=info
